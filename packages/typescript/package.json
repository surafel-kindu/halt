{
  "name": "halt-rate",
  "version": "0.5.0",
  "description": "SaaS-aware, cross-language rate limiting: per-user/API-key/plan limits, quotas, weighted endpoints, abuse controls, atomic Redis, and built-in observability",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/adapters/express.d.mts",
        "default": "./dist/adapters/express.mjs"
      },
      "require": {
        "types": "./dist/adapters/express.d.ts",
        "default": "./dist/adapters/express.js"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/adapters/next.d.mts",
        "default": "./dist/adapters/next.mjs"
      },
      "require": {
        "types": "./dist/adapters/next.d.ts",
        "default": "./dist/adapters/next.js"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/adapters/hono.d.mts",
        "default": "./dist/adapters/hono.mjs"
      },
      "require": {
        "types": "./dist/adapters/hono.d.ts",
        "default": "./dist/adapters/hono.js"
      }
    },
    "./fastify": {
      "import": {
        "types": "./dist/adapters/fastify.d.mts",
        "default": "./dist/adapters/fastify.mjs"
      },
      "require": {
        "types": "./dist/adapters/fastify.d.ts",
        "default": "./dist/adapters/fastify.js"
      }
    },
    "./graphql": {
      "import": {
        "types": "./dist/adapters/graphql.d.mts",
        "default": "./dist/adapters/graphql.mjs"
      },
      "require": {
        "types": "./dist/adapters/graphql.d.ts",
        "default": "./dist/adapters/graphql.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rate-limiting",
    "throttling",
    "middleware",
    "express",
    "nextjs",
    "saas",
    "quota",
    "api-keys",
    "redis",
    "distributed",
    "observability",
    "opentelemetry"
  ],
  "author": "Halt Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/surafel-kindu/halt"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "next": "^14.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.54.0",
    "ioredis": "^5.3.0",
    "@opentelemetry/api": "^1.7.0",
    "hono": "^4.0.0",
    "fastify": "^4.0.0",
    "prettier": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "next": "^14.0.0",
    "ioredis": "^5.3.0",
    "@opentelemetry/api": "^1.7.0",
    "hono": "^3.0.0 || ^4.0.0",
    "fastify": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    }
  }
}
